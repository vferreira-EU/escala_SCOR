    drawPoligonoRIR() {
        if (!this._mlReady) return;
        const coords = this.poligonoCoords.map(c => [c[0], c[1]]);
        this.map.addSource('poligono-rir', {type:'geojson', data:{type:'Feature',geometry:{type:'Polygon',coordinates:[coords]}}});
        this.map.addLayer({id:'poligono-fill',type:'fill',source:'poligono-rir',paint:{'fill-color':'#E30613','fill-opacity':0.06}});
        this.map.addLayer({id:'poligono-line',type:'line',source:'poligono-rir',paint:{'line-color':'#E30613','line-width':2,'line-dasharray':[4,3],'line-opacity':0.85}});
    }

    pontoNoPoligono(lon, lat) {
        const poly = this.poligonoCoords; let inside = false;
        for (let i=0, j=poly.length-1; i<poly.length; j=i++) {
            const xi=poly[i][0],yi=poly[i][1],xj=poly[j][0],yj=poly[j][1];
            if (((yi>lat)!==(yj>lat)) && (lon<(xj-xi)*(lat-yi)/(yj-yi)+xi)) inside=!inside;
        }
        return inside;
    }

