    loadDensidadeHistorico() {
        if (!this.gridCoords.size) return;
        const cellsList=this.quadriculasVodafone.join(',');
        const _sql=`SELECT bucket,SUM(c3) AS media_c3,SUM(c4) AS media_c4,COUNT(*) AS n_celulas FROM (SELECT grid_id,floor(date/1200000)*1200000 AS bucket,COALESCE("C3",0)::DOUBLE AS c3,COALESCE("C4",0)::DOUBLE AS c4,date,MAX(date) OVER (PARTITION BY grid_id,floor(date/1200000)) AS max_date_in_bucket FROM raw_coi_tematica_lx_indicadores_a WHERE grid_id IN (${cellsList}) AND date>=(SELECT MAX(date)-18000000 FROM raw_coi_tematica_lx_indicadores_a WHERE grid_id IN (${cellsList}))) t WHERE date=max_date_in_bucket GROUP BY bucket ORDER BY bucket ASC`;
        CCOC.Functions.ac_executa_crate_sql(_sql,'select',500)
            .then((data) => {
                if (!data||!data.length){this.densidadeHistorico=[];}
                else{console.log(`📊 Histórico: ${data.length} buckets`);this.densidadeHistorico=data.map(r=>({bucket:Number(r.bucket),media_c3:Number(r.media_c3)||0,media_c4:Number(r.media_c4)||0,n_celulas:Number(r.n_celulas)||0}));}
                this.renderDensidadeChart();
            })
            .catch(err=>{console.warn("📊 Histórico falhou:",err);this.densidadeHistorico=[];this.renderDensidadeChart();});
    }

    renderDensidadeChart() {
        const canvas=document.getElementById('densidade-chart'), noData=document.getElementById('chart-no-data'), lastUpd=document.getElementById('chart-last-update');
        if (!canvas) return;
        const dados=this.densidadeHistorico;
        if (!dados.length){canvas.style.display='none';if(noData)noData.style.display='block';this._chartMeta=null;return;}
        canvas.style.display='block'; if(noData)noData.style.display='none';
        const ultimoBucket=dados[dados.length-1].bucket;
        if (lastUpd) lastUpd.textContent='último: '+moment(ultimoBucket).format('HH:mm');
        const ctx=canvas.getContext('2d'), W=canvas.offsetWidth||332, H=140;
        canvas.width=W; canvas.height=H; ctx.clearRect(0,0,W,H);
        const mL=38,mR=8,mT=10,mB=28,pW=W-mL-mR,pH=H-mT-mB,n=dados.length;
        const maxVal=Math.max(...dados.map(d=>d.media_c3),1), yMax=Math.ceil(maxVal/50)*50||50;
        const barGap=2, barW=Math.max(4,(pW/n)-barGap);
        this._chartMeta={marginLeft:mL,plotW:pW,plotH:pH,marginTop:mT,marginBottom:mB,barW,barGap,n,dados,W,H,yMax};
        ctx.strokeStyle='rgba(255,255,255,0.08)'; ctx.lineWidth=1;
        for(let i=0;i<=4;i++){const y=mT+pH-(i/4)*pH;ctx.beginPath();ctx.moveTo(mL,y);ctx.lineTo(mL+pW,y);ctx.stroke();ctx.fillStyle='rgba(255,179,184,0.7)';ctx.font='8px Segoe UI,Arial';ctx.textAlign='right';const val=Math.round((i/4)*yMax);ctx.fillText(val>999?(val/1000).toFixed(1)+'k':val,mL-3,y+3);}
        dados.forEach((d,i)=>{
            const x=mL+(i/n)*pW+barGap/2, barH=(d.media_c3/yMax)*pH, y=mT+pH-barH, isLast=i===n-1;
            const grad=ctx.createLinearGradient(0,y,0,mT+pH);
            grad.addColorStop(0,isLast?'rgba(255,60,80,0.95)':'rgba(227,6,19,0.75)');
            grad.addColorStop(1,isLast?'rgba(180,20,35,0.7)':'rgba(130,0,10,0.4)');
            ctx.fillStyle=grad; ctx.beginPath(); ctx.roundRect(x,y,barW,barH,[2,2,0,0]); ctx.fill();
            if(isLast){ctx.fillStyle='rgba(255,255,255,0.25)';ctx.beginPath();ctx.roundRect(x,y,barW,Math.min(4,barH),[2,2,0,0]);ctx.fill();}
        });
        ctx.fillStyle='rgba(255,179,184,0.8)'; ctx.font='8px Segoe UI,Arial'; ctx.textAlign='center';
        dados.forEach((d,i)=>{const x=mL+(i/n)*pW+barW/2+barGap/2,m=moment(d.bucket);if(m.minutes()===0||i===n-1){ctx.fillText(m.format('HH:mm'),x,H-mB+12);ctx.strokeStyle='rgba(255,179,184,0.4)';ctx.lineWidth=1;ctx.beginPath();ctx.moveTo(x,mT+pH+2);ctx.lineTo(x,mT+pH+5);ctx.stroke();}});
        ctx.strokeStyle='rgba(255,255,255,0.15)'; ctx.lineWidth=1; ctx.beginPath(); ctx.moveTo(mL,mT); ctx.lineTo(mL,mT+pH); ctx.stroke();
        this._setupChartTooltip();
    }

    _setupChartTooltip() {
        const canvas=document.getElementById('densidade-chart'), overlay=document.getElementById('densidade-chart-overlay');
        if (!canvas||canvas._tooltipBound) return; canvas._tooltipBound=true;
        const tt=document.getElementById('chart-tooltip-el'); if (!tt) return;
        const fmt=(v)=>Math.round(v).toLocaleString('pt-PT');
        canvas.addEventListener('mousemove', (e) => {
            if (!this._chartMeta){tt.style.display='none';return;}
            const {marginLeft,plotW,barW,barGap,n,dados}=this._chartMeta;
            const rect=canvas.getBoundingClientRect(), mouseX=e.clientX-rect.left;
            let found=null;
            dados.forEach((d,i)=>{const xL=marginLeft+(i/n)*plotW+barGap/2;if(mouseX>=xL&&mouseX<=xL+barW)found={d,i};});
            if (!found){tt.style.display='none';return;}
            const {d,i}=found, prev=i>0?dados[i-1]:null;
            const horaInicio=moment(d.bucket).format('HH:mm'), horaFim=moment(d.bucket+1200000).format('HH:mm');
            let varHTML='';
            if (prev){const diff=d.media_c3-prev.media_c3,diffPct=prev.media_c3>0?((diff/prev.media_c3)*100).toFixed(1):'—';
                if(Math.abs(diff)<1)varHTML=`<div class="ctt-row ctt-flat">▶ estável</div>`;
                else if(diff>0)varHTML=`<div class="ctt-row ctt-up">▲ +${fmt(diff)} disp. (+${diffPct}%)</div>`;
                else varHTML=`<div class="ctt-row ctt-down">▼ ${fmt(diff)} disp. (${diffPct}%)</div>`;}
            const pctRoaming=d.media_c3>0?((d.media_c4/d.media_c3)*100).toFixed(1):'—';
            tt.innerHTML=`<div class="ctt-hora">📱 ${horaInicio} — ${horaFim}</div><div class="ctt-row">Total recinto (C3): <b>${fmt(d.media_c3)}</b></div><div class="ctt-row">Roaming (C4): <b>${fmt(d.media_c4)}</b> · <b>${pctRoaming}%</b></div>${varHTML}`;
            const overlayRect=overlay.getBoundingClientRect(), canvasRect=canvas.getBoundingClientRect();
            let left=(e.clientX-overlayRect.left)+12, top=(canvasRect.top-overlayRect.top)+e.offsetY-10;
            if(left+180>overlay.offsetWidth-4)left=(e.clientX-overlayRect.left)-180-12;
            if(top<0)top=4;
            tt.style.left=left+'px'; tt.style.top=top+'px'; tt.style.display='block';
        });
        canvas.addEventListener('mouseleave', ()=>{tt.style.display='none';});
    }

    rebuildAfluenciaLayer() {
        if (!this._mlReady) return;
        const maxValor=this.devicesMode==='c4'?this.devicesMaxC4:this.devicesMaxC3;
        const radius=Number((document.getElementById('heat-radius')||{}).value||35);
        const feats=(this.devicesData||[]).map(r=>{
            const coords=this.gridCoords.get(Number(r.grid_id)); if(!coords)return null;
            const v=Number(r[this.devicesMode])||0;
            return{type:'Feature',geometry:{type:'Point',coordinates:coords},
                properties:{weight:Math.min(1,v/maxValor)}};
        }).filter(Boolean);
        this._mlSetSource('heat-src', feats);
        if (this.map.getLayer('heat-layer'))
            this.map.setPaintProperty('heat-layer','heatmap-radius',radius);
        const btnDen=document.getElementById('btn-densidade');
        const v=btnDen&&btnDen.classList.contains('active')?'visible':'none';
        if (this.map.getLayer('heat-layer')) this.map.setLayoutProperty('heat-layer','visibility',v);
    }

    updateDensidadeCard(totalC3, totalC4) {
