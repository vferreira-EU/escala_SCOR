        const cellsList=this.quadriculasVodafone.join(',');
        const _sql=`SELECT grid_id,COALESCE("C3",0)::DOUBLE AS c3,COALESCE("C4",0)::DOUBLE AS c4,date FROM raw_coi_tematica_lx_indicadores_a WHERE grid_id IN (${cellsList}) AND date IN (SELECT MAX(date) FROM raw_coi_tematica_lx_indicadores_a WHERE grid_id IN (${cellsList}))`;
