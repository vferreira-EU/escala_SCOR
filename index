    // ══════════════════════════════════════════════════════════════════════
    // ARCOS ANIMADOS — Modelo de Gravidade Espacial (Valter Ferreira 2026)
    // T(i) = C6(i) / d(i, recinto)^β — convergência para o Parque Tejo
    // Grids alargadas: Cais do Sodré, Baixa, Areeiro, Entrecampos, etc.
    // Partículas animadas percorrem cada arco em loop contínuo
    // ══════════════════════════════════════════════════════════════════════

    ARCOS_BETA       = 1.8;
    ARCOS_TOP        = 40;
    ARCOS_MIN_DIST   = 500;   // metros — só arcos com alguma distância
    ARCOS_PARTICLES  = 3;     // partículas por arco
