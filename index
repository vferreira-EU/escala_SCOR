    _mlSetSource(id, features) {
        const src = this.map?.getSource(id);
        if (src) src.setData({type:'FeatureCollection', features});
    }

    _mlLayerVisible(ids, visible) {
        const v = visible ? 'visible' : 'none';
        (Array.isArray(ids)?ids:[ids]).forEach(id => {
            if (this.map?.getLayer(id)) this.map.setLayoutProperty(id,'visibility',v);
        });
    }

    _mlClick(e) {
        const layers = ['waze-jams-line','waze-alerts-sym','carris-body','gopis-sym','sensores-body'];
        const feats = this.map.queryRenderedFeatures(e.point, {layers});
        if (!feats.length) return;
        const f = feats[0], p = f.properties;
        let html = '';
        if (f.layer.id === 'waze-jams-line')
            html = `<div class="tt-title">🚦 ${p.name||'Via'}</div><div class="tt-row">Nível: <b>${p.level}/5</b></div>`;
        else if (f.layer.id === 'waze-alerts-sym')
            html = `<div class="tt-title">${this.getAlertTitle(p.type,p.subtype)}</div>${p.street?`<div class="tt-row">📍 ${p.street}</div>`:''}`;
        else if (f.layer.id === 'carris-body')
            html = `<div class="tt-title">🚌 ${p.route_number||'?'}</div><div class="tt-row">${p.direction==='ASC'?'▲ Sentido ida':'▼ Sentido volta'}</div>${p.plate?`<div class="tt-row">🪪 ${p.plate}</div>`:''}`;
        else if (f.layer.id === 'gopis-sym')
            html = `<div class="tt-title">${p.emoji||'📍'} ${p.typology1||''}</div>${p.address?`<div class="tt-row">📍 ${p.address}</div>`:''}${p.date?`<div class="tt-row">🕒 ${p.date}</div>`:''}`;
        else if (f.layer.id === 'sensores-body')
            html = `<div class="tt-title">${p.emoji} ${p.station||''}</div>`;
        if (!html) return;
        const tt = document.getElementById('alert-tooltip');
        if (tt) { tt.innerHTML=html; tt.style.display='block'; tt.style.left=(e.point.x+14)+'px'; tt.style.top=(e.point.y+14)+'px'; }
    }

    _mlHover(e) {
        const layers = ['waze-jams-line','waze-alerts-sym','carris-body','gopis-sym','sensores-body','arcos-halo-layer'];
        const feats = this.map.queryRenderedFeatures(e.point, {layers});
        this.map.getCanvas().style.cursor = feats.length ? 'pointer' : '';
        const tt = document.getElementById('alert-tooltip');
        if (!feats.length && tt) { tt.style.display='none'; return; }
    }

    setupTooltipML() {
        // Tooltip via click (_mlClick) — já configurado em _initMLSources
        const mapEl = document.getElementById('map');
        if (mapEl) mapEl.addEventListener('mouseleave', () => {
            const tt = document.getElementById('alert-tooltip');
            if (tt) tt.style.display = 'none';
        });
    }

    updateZoomIndicator() {
        const el = document.getElementById('zoom-indicator'); if (!el||!this.map) return;
        const zoom = this.map.getZoom();
        const escala = zoom<13?'cidade':zoom<15?'recinto+envolvente':zoom<17?'recinto':'pormenor';
        el.innerHTML = `<div class="zoom-main">🎸 Zoom <b>${zoom.toFixed(1)}</b></div><div class="zoom-sub">${escala}</div>`;
    }

