    _arcos_grids  = [];
    _arcos_pairs  = [];   // [{src, T, vol, pts}] — pares calculados
    _arcos_canvas = null;
    _arcos_ctx    = null;
    _arcos_raf    = null;
    _arcos_t      = 0;    // tempo global da animação 0→1 em loop

    _initArcos() {
        // Canvas sobre o mapa ML
        const mapEl = document.getElementById('map');
        if (!mapEl) return;
        this._arcos_canvas = document.createElement('canvas');
        this._arcos_canvas.style.cssText = 'position:absolute;inset:0;width:100%;height:100%;pointer-events:none;z-index:200;';
        mapEl.appendChild(this._arcos_canvas);
        this._arcos_ctx = this._arcos_canvas.getContext('2d');

        // Redesenhar quando o mapa move
        this.map.on('move', () => this._arcosRedraw());
        this.map.on('zoom', () => this._arcosRedraw());

        // Arrancar animação
        this._arcosAnimate();

        // Carregar dados
        this._loadArcosData();
        console.log('🌐 Arcos animados iniciados');
    }

    _loadArcosData() {
        const sql = `SELECT grid_id,
                COALESCE("C5",0)::DOUBLE AS c5,
                COALESCE("C6",0)::DOUBLE AS c6
            FROM raw_coi_tematica_lx_indicadores_a
            WHERE grid_id IN (${this.ARCOS_SQL_IDS})
              AND date = (SELECT MAX(date) FROM raw_coi_tematica_lx_indicadores_a WHERE grid_id=3181)`;
        CCOC.Functions.ac_executa_crate_sql(sql, 'select', 5000)
            .then(data => {
                if (!data||!data.length) { console.warn('🌐 Arcos: 0 registos'); return; }
                this._arcos_grids = data.map(r => {
                    const m = this.ARCOS_GRID_LOOKUP[String(r.grid_id)];
                    if (!m) return null;
                    return {grid_id:r.grid_id,lon:m.lon,lat:m.lat,nome:m.nome||'',
                            C5:Number(r.c5)||0,C6:Number(r.c6)||0};
                }).filter(Boolean);
                console.log(`🌐 Arcos: ${this._arcos_grids.length} grids`);
                this._buildArcosPairs();
            })
            .catch(err => console.warn('Arcos data falhou:', err));
    }

    _haversineA(la1,lo1,la2,lo2) {
        const R=6371000,dLat=(la2-la1)*Math.PI/180,dLon=(lo2-lo1)*Math.PI/180;
        const a=Math.sin(dLat/2)**2+Math.cos(la1*Math.PI/180)*Math.cos(la2*Math.PI/180)*Math.sin(dLon/2)**2;
        return R*2*Math.atan2(Math.sqrt(a),Math.sqrt(1-a));
    }

    _buildArcosPairs() {
        const pairs = this._arcos_grids.map(g => {
            const d = this._haversineA(g.lat,g.lon,this.PARQUE_LAT,this.PARQUE_LON);
            if (d < this.ARCOS_MIN_DIST || g.C6 < 3) return null;
            return {g, d, T: g.C6 / Math.pow(d, this.ARCOS_BETA)};
        }).filter(Boolean);
        pairs.sort((a,b) => b.T-a.T);
        const maxT = pairs[0]?.T || 1;
        this._arcos_pairs = pairs.slice(0, this.ARCOS_TOP).map(({g,d,T}) => {
            const vol = Math.min(1, T/maxT);
            // Velocidade: arcos maiores movem mais lento
            const speed = 0.004 + (1-vol)*0.003;
            // Partículas com fases distribuídas para não ficarem juntas
            const particles = Array.from({length:this.ARCOS_PARTICLES}, (_,i) => ({
                phase: i/this.ARCOS_PARTICLES,  // 0, 0.33, 0.66
                speed: speed * (0.85 + i*0.1)   // velocidades ligeiramente diferentes
            }));
            return {g, vol, T, d, particles};
        });
        console.log(`🌐 Arcos pares: ${this._arcos_pairs.length}`);
        this._arcosRedraw();
    }

    // Converter lon/lat → pixel via MapLibre
    _ll2pxML(lon, lat) {
        return this.map.project([lon, lat]);
    }

    // Ponto ao longo de uma curva Bézier quadrática (t ∈ 0→1)
    _bezierPt(p0x,p0y,p1x,p1y,p2x,p2y,t) {
        const mt=1-t;
        return [mt*mt*p0x+2*mt*t*p1x+t*t*p2x, mt*mt*p0y+2*mt*t*p1y+t*t*p2y];
    }

    _arcosAnimate() {
        this._arcos_raf = requestAnimationFrame(() => this._arcosAnimate());
        this._arcos_t = (this._arcos_t + 0.004) % 1;
        this._arcosRedraw();
    }

    _arcosRedraw() {
        const canvas = this._arcos_canvas;
        const ctx    = this._arcos_ctx;
        if (!canvas || !ctx || !this.map) return;

        const mapEl = document.getElementById('map');
        canvas.width  = mapEl.offsetWidth;
        canvas.height = mapEl.offsetHeight;
        ctx.clearRect(0,0,canvas.width,canvas.height);

        if (!this._arcos_pairs.length) return;

        const dst = this._ll2pxML(this.PARQUE_LON, this.PARQUE_LAT);

        this._arcos_pairs.forEach(({g, vol, particles}) => {
            const src = this._ll2pxML(g.lon, g.lat);
            const dx=dst.x-src.x, dy=dst.y-src.y;
            const len=Math.sqrt(dx*dx+dy*dy)+1e-10;
            const cx=(src.x+dst.x)/2-(dy/len)*len*0.35;
            const cy=(src.y+dst.y)/2+(dx/len)*len*0.35;

            // ── Linha de fundo (arco estático subtil) ──
            ctx.save();
            ctx.beginPath(); ctx.moveTo(src.x,src.y);
            ctx.quadraticCurveTo(cx,cy,dst.x,dst.y);
            ctx.strokeStyle = `rgba(255,140,0,${0.15*vol})`;
            ctx.lineWidth   = 0.5 + vol;
            ctx.stroke();
            ctx.restore();

            // ── Partículas animadas ──
            particles.forEach(({phase, speed}) => {
                const t = ((this._arcos_t * speed / 0.004) + phase) % 1;
                const [px,py] = this._bezierPt(src.x,src.y,cx,cy,dst.x,dst.y,t);

                // Tamanho e opacidade: maior no meio do percurso
                const midT = 1 - Math.abs(t-0.5)*2; // 0 nas pontas, 1 no meio
                const r  = 2.5 + midT*3*vol;
                const op = 0.4 + midT*0.6;

                // Glow exterior
                const glow = ctx.createRadialGradient(px,py,0,px,py,r*3.5);
                glow.addColorStop(0,   `rgba(255,200,50,${op*vol*0.8})`);
                glow.addColorStop(0.4, `rgba(255,120,0,${op*vol*0.4})`);
                glow.addColorStop(1,   'rgba(0,0,0,0)');
                ctx.save();
                ctx.beginPath(); ctx.arc(px,py,r*3.5,0,Math.PI*2);
                ctx.fillStyle=glow; ctx.fill();
                ctx.restore();

                // Núcleo brilhante
                const core = ctx.createRadialGradient(px,py,0,px,py,r);
                core.addColorStop(0,   `rgba(255,255,200,${op})`);
                core.addColorStop(0.5, `rgba(255,160,0,${op*0.9})`);
                core.addColorStop(1,   `rgba(220,60,0,${op*0.3})`);
                ctx.save();
                ctx.beginPath(); ctx.arc(px,py,r,0,Math.PI*2);
                ctx.fillStyle=core; ctx.fill();
                ctx.restore();
            });
        });
    }

