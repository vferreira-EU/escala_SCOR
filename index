    loadCarris() {
        const desdeMillis=Date.now()-(5*60*1000);
        const linhasList=this.linhasCarrisRIR.map(l=>`'${l}'`).join(',');
        const _sql=`SELECT vehicle_id,vehicle_license_plate,route_id,route_number,direction,latitude,longitude,last_updated FROM raw_coi_tematica_carris WHERE validity_ts IS NULL AND last_updated>=${desdeMillis} AND latitude IS NOT NULL AND longitude IS NOT NULL AND route_number IN (${linhasList})`;
        CCOC.Functions.ac_executa_crate_sql(_sql,'select',2000)
            .then((data) => {
                if (!data) data=[];
                const feats=[]; let dentroPoligono=0; const linhasDentro=new Set();
                const seen=new Set();
                data.forEach(item => {
                    if (seen.has(item.vehicle_id)) return; seen.add(item.vehicle_id);
                    const lon=Number(item.longitude), lat=Number(item.latitude);
                    if (isNaN(lon)||isNaN(lat)) return;
                    const inside=this.pontoNoPoligono(lon,lat);
