    loadGopis() {
        const desdeMillis=moment().startOf('day').valueOf();
        const tipologiasList=Object.keys(this.gopiTipologias).map(t=>`'${t.replace(/'/g,"''")}'`).join(',');
        const _sql=`SELECT init_datetime,date_format('%Y-%m-%d %H:%i','Europe/Lisbon',init_datetime) AS date,status,typology_level_1,typology_level_2,position,address FROM raw_coi_gopiocurrencias WHERE validity_ts IS NULL AND init_datetime>=${desdeMillis} AND typology_level_1 IN (${tipologiasList})`;
        CCOC.Functions.ac_executa_crate_sql(_sql,'select',5000)
            .then((data) => {
                if (!data) data=[];
                const feats=[];
                data.forEach(r=>{
                    const coords=this.parsePosition(r.position);
                    if (!coords||!this.pontoNoPoligono(coords.lon,coords.lat)) return;
                    feats.push({type:'Feature',geometry:{type:'Point',coordinates:[coords.lon,coords.lat]},
                        properties:{typology1:r.typology_level_1,typology2:r.typology_level_2,
                            status:r.status,date:r.date,address:r.address,
                            emoji:this.gopiTipologias[r.typology_level_1]||'📍'}});
                });
                console.log(`📋 GOPIs: ${feats.length}`);
                this._mlSetSource('gopis', feats);
                this.updateGopisCard(feats);
            })
            .catch(err=>{console.warn("GOPIs:",err);this.updateGopisCard([]);});
    }

    updateGopisCard(features) {
        const el=document.getElementById('gopis-card'); if (!el) return;
        const getP=(f,k)=>f.properties?.[k]??f.get?.(k);
        if (!features.length){el.innerHTML=`<b>📋 Ocorrências</b><div class="big-number">0</div><div class="big-number-sub">sem registos hoje</div>`;return;}
        const porTipo={};
        features.forEach(f=>{const t=getP(f,'typology1')||'Outras';porTipo[t]=(porTipo[t]||0)+1;});
        const top4=Object.entries(porTipo).sort((a,b)=>b[1]-a[1]).slice(0,4);
        let bd='<div class="gopi-breakdown">'; top4.forEach(([t,n])=>{const emoji=this.gopiTipologias[t]||'📍';const lbl=t.length>24?t.substring(0,22)+'…':t;bd+=`${emoji} ${lbl}: <b>${n}</b><br>`;}); bd+='</div>';
        el.innerHTML=`<b>📋 Ocorrências</b><div class="big-number">${features.length}</div><div class="big-number-sub">na área em análise · hoje</div>${bd}`;
    }

