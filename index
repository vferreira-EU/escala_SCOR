    // ─── Classificações ─────────────────────────────────────────

    classificaAr(pm10, pm25, no2, o3) {
        const niveis = [];
        if (pm10 != null) { if (pm10>100) niveis.push(5); else if (pm10>50) niveis.push(4); else if (pm10>40) niveis.push(3); else if (pm10>20) niveis.push(2); else niveis.push(1); }
        if (pm25 != null) { if (pm25>75) niveis.push(5); else if (pm25>50) niveis.push(4); else if (pm25>25) niveis.push(3); else if (pm25>15) niveis.push(2); else niveis.push(1); }
        if (no2  != null) { if (no2>200)  niveis.push(5); else if (no2>100)  niveis.push(4); else if (no2>50)  niveis.push(3); else if (no2>25)  niveis.push(2); else niveis.push(1); }
        if (o3   != null) { if (o3>240)   niveis.push(5); else if (o3>180)   niveis.push(4); else if (o3>120)  niveis.push(3); else if (o3>60)   niveis.push(2); else niveis.push(1); }
        if (!niveis.length) return { nivel:0, label:'Sem dados', cor:'#888' };
        const pior = Math.max(...niveis);
        return { nivel:pior, ...{ 1:{label:'Bom',cor:'#3a9656'}, 2:{label:'Razoável',cor:'#a3c945'}, 3:{label:'Médio',cor:'#e8c547'}, 4:{label:'Fraco',cor:'#ff8a00'}, 5:{label:'Mau',cor:'#d64545'} }[pior] };
    }

    classificaRuido(laeq) {
        if (laeq==null||isNaN(laeq)) return {nivel:0,label:'Sem dados',cor:'#888',emoji:'⚪'};
        if (laeq<55) return {nivel:1,label:'Confortável',cor:'#3a9656',emoji:'🟢'};
        if (laeq<65) return {nivel:2,label:'Moderado',cor:'#e8c547',emoji:'🟡'};
        if (laeq<75) return {nivel:3,label:'Ruidoso',cor:'#ff8a00',emoji:'🟠'};
        return {nivel:4,label:'Muito ruidoso',cor:'#d64545',emoji:'🔴'};
    }

    classificaTemp(t) {
        if (t==null||isNaN(t)) return {label:'Sem dados',cor:'#888',emoji:'🌡️'};
        if (t<10) return {label:'Muito frio',cor:'#5fa3ed',emoji:'🥶'};
        if (t<18) return {label:'Fresco',cor:'#7fb3ed',emoji:'❄️'};
        if (t<24) return {label:'Confortável',cor:'#3a9656',emoji:'😊'};
        if (t<30) return {label:'Quente',cor:'#ff8a00',emoji:'☀️'};
        return {label:'Muito quente',cor:'#d64545',emoji:'🥵'};
    }

    sanitizaTemp(v)     { const n=Number(v); return (!isNaN(n)&&n>-10&&n<60)   ?n:null; }
    sanitizaHumidade(v) { const n=Number(v); return (!isNaN(n)&&n>=0&&n<=100)  ?n:null; }
    sanitizaPressao(v)  { const n=Number(v); return (!isNaN(n)&&n>800&&n<1100) ?n:null; }
    sanitizaRuido(v)    { const n=Number(v); return (!isNaN(n)&&n>0&&n<140)    ?n:null; }
    sanitizaPoluente(v) { const n=Number(v); return (!isNaN(n)&&n>=0&&n<2000)  ?n:null; }

