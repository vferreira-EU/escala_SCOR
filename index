    getAlertTitle(type, subtype) {
        const subtypes = { HAZARD_ON_ROAD:"⚠️ Perigo na estrada", HAZARD_ON_ROAD_POT_HOLE:"🕳️ Buraco na estrada", HAZARD_ON_ROAD_CONSTRUCTION:"🚧 Obras na estrada", HAZARD_ON_ROAD_OBJECT:"⚠️ Objeto na estrada", HAZARD_ON_ROAD_TRAFFIC_LIGHT_FAULT:"🚦 Semáforo avariado", HAZARD_ON_ROAD_LANE_CLOSED:"⛔ Faixa cortada", HAZARD_ON_ROAD_CAR_STOPPED:"🚗 Carro parado na via", HAZARD_ON_SHOULDER:"⚠️ Perigo na berma", HAZARD_ON_SHOULDER_CAR_STOPPED:"🚙 Carro parado na berma", HAZARD_WEATHER:"🌧️ Condições meteorológicas", ROAD_CLOSED_EVENT:"🎪 Estrada cortada (evento)", ROAD_CLOSED_CONSTRUCTION:"🚧 Estrada cortada (obras)", ROAD_CLOSED_HAZARD:"⛔ Estrada cortada (perigo)", ACCIDENT_MAJOR:"🚨 Acidente grave", ACCIDENT_MINOR:"🚗 Acidente ligeiro" };
        if (subtype && subtypes[subtype]) return subtypes[subtype];
        const types = { ACCIDENT:"🚗 Acidente", ROAD_CLOSED:"⛔ Estrada cortada", CONSTRUCTION:"🚧 Obras", JAM:"🚦 Trânsito", HAZARD:"⚠️ Perigo" };
        return types[type]||"⚠️ Alerta";
    }

    getColor(level) { return level<=2?"#99FF00":level===3?"#FF9900":"#FF3300"; }

    labelParam(p) { return {pm10:'PM10',pm25:'PM2.5',no2:'NO₂',o3:'O₃',so2:'SO₂',laeq:'LAeq',temperature:'Temp',humidity:'Humidade',pressure:'Pressão'}[p]||p; }
    unidadeParam(p) { return {pm10:' µg/m³',pm25:' µg/m³',no2:' µg/m³',o3:' µg/m³',so2:' µg/m³',laeq:' dBA',temperature:' °C',humidity:' %',pressure:' hPa'}[p]||''; }

    parsePosition(pos) {
        if (!pos) return null;
        try {
            if (typeof pos==='object'&&pos.coordinates) return {lon:Number(pos.coordinates[0]),lat:Number(pos.coordinates[1])};
            if (typeof pos==='string') { const o=JSON.parse(pos); if (o.coordinates) return {lon:Number(o.coordinates[0]),lat:Number(o.coordinates[1])}; }
        } catch(e) {}
        return null;
    }

    // ─── WAZE TRÁFEGO ───────────────────────────────────────────

    loadWaze() {
        const query = { entities:[{idPattern:".*",type:"WAZE.jams"}], scopes:[{type:"FIWARE::StringQuery",value:"status==active"}], attributes:['level','delay','endNode','position'] };
        CCOC.Entities.query(query, {limit:1000}, "fs_lisbon", "/cml_external")
            .then((data) => {
                const feats=[];
                data.forEach((item) => {
                    if (!item.position?.value?.geometries?.length) return;
                    const geom=item.position.value.geometries[0];
                    if (!this.extrairCoordsParaTeste(geom).some(c=>this.pontoNoPoligono(c[0],c[1]))) return;
                    feats.push({type:'Feature',geometry:geom,
                        properties:{level:item.level?.value??1,delay:item.delay?.value??0,name:item.endNode?.value||''}});
                });
                console.log(`🚗 Waze jams: ${feats.length}`);
                this._wazeJamsFeats = feats;
                this._mlSetSource('waze-jams', feats);
                this.updateTrafegoCard(feats); this.markUpdated();
            })
            .catch(err => { console.warn("Waze tráfego falhou:", err); this.updateTrafegoCard([]); });
    }

    extrairCoordsParaTeste(geom) {
        if (geom.type==='Point') return [geom.coordinates];
        if (geom.type==='LineString') return geom.coordinates;
        if (geom.type==='MultiLineString'||geom.type==='Polygon') return geom.coordinates.flat();
        if (geom.type==='MultiPolygon') return geom.coordinates.flat(2);
        return [];
    }

    updateTrafegoCard(features) {
        const el=document.getElementById('trafego-card'); if (!el) return;
        const getP = (f,k) => f.properties?.[k] ?? f.get?.(k);
        if (!features.length) { el.innerHTML=`<b>🚗 Tráfego</b><div class="big-number">0</div><div class="big-number-sub">sem engarrafamentos</div>`; return; }
        const nivelMedio=features.map(f=>Number(getP(f,'level'))||0).reduce((a,c)=>a+c,0)/features.length;
        const graves=features.filter(f=>Number(getP(f,'level'))>=4).length;
        const delayMedio=features.map(f=>Number(getP(f,'delay'))||0).reduce((a,c)=>a+c,0)/features.length;
        el.innerHTML=`<b>🚗 Tráfego</b><div class="big-number">${features.length}</div><div class="big-number-sub">engarrafamentos · nível médio ${nivelMedio.toFixed(1)}/5</div>${graves>0?`<div style="font-size:10px;color:#ff6b7a;margin-top:4px">🔴 ${graves} graves (nível ≥4)</div>`:''}<div style="font-size:10px;color:#ffb3b8;margin-top:2px">Atraso médio: <b>${Math.round(delayMedio)}s</b></div>`;
    }

