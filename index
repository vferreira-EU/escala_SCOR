    // ─── SENSORES AMBIENTAIS ─────────────────────────────────────

    preloadSensores() {
        const _sql=`SELECT entity_id,station,sensortype,status,lastreading,location,laeq,pm10,pm25,no2,o3,so2,temperature,humidity,pressure FROM raw_coi_tematica_environmentalsensor WHERE validity_ts IS NULL AND sensortype IN ('QA','RU','ME')`;
        CCOC.Functions.ac_executa_crate_sql(_sql,'select',5000)
            .then((data) => {
                if (!data) data=[];
                this.sensoresAllData=data.map(r=>{
                    const coords=this.parsePosition(r.location);
                    return {...r,_lon:coords?coords.lon:null,_lat:coords?coords.lat:null,
                        temperature:this.sanitizaTemp(r.temperature),humidity:this.sanitizaHumidade(r.humidity),pressure:this.sanitizaPressao(r.pressure),
                        laeq:this.sanitizaRuido(r.laeq),pm10:this.sanitizaPoluente(r.pm10),pm25:this.sanitizaPoluente(r.pm25),
                        no2:this.sanitizaPoluente(r.no2),o3:this.sanitizaPoluente(r.o3),so2:this.sanitizaPoluente(r.so2)};
                }).filter(r=>r._lon!=null&&this.pontoNoPoligono(r._lon,r._lat));
                console.log(`🌡️ Sensores no polígono: ${this.sensoresAllData.length}`);
                // Definir defaults na primeira carga
                if (!this.estacaoQASelec) {
                    const qaList=this.sensoresAllData.filter(r=>r.sensortype==='QA');
                    const chen=qaList.find(r=>r.station&&r.station.toLowerCase().includes('chen he'));
                    this.estacaoQASelec=chen?chen.entity_id:(qaList[0]?.entity_id||null);
                }
                if (!this.estacaoRUSelec) {
                    const ruList=this.sensoresAllData.filter(r=>r.sensortype==='RU');
                    const mBotas=ruList.find(r=>r.station&&r.station.toLowerCase().includes('mário botas'));
                    this.estacaoRUSelec=mBotas?mBotas.entity_id:(ruList[0]?.entity_id||null);
                }
                this.refreshSensoresLayer();
                this._renderEstacoesSelector();
                // Redraw para aplicar highlight nos defaults
                if (this.sensoresLayer) this.sensoresLayer.changed();
                this.preloadSensoresD1();
            })
            .catch(err=>{console.warn("Sensores:",err);this.sensoresAllData=[];this.updateAmbienteCards();});
    }

    preloadSensoresD1() {
        const d1Center=Date.now()-86400000, d1From=d1Center-1800000, d1To=d1Center+1800000;
        const entityIds=this.sensoresAllData.filter(r=>r.sensortype==='QA'||r.sensortype==='RU').map(r=>`'${r.entity_id}'`).join(',');
        if (!entityIds){this.sensoresD1={};this.updateAmbienteCards();return;}
        const _sql=`SELECT entity_id,laeq,pm10,pm25,no2,o3,so2,validity_ts FROM raw_coi_tematica_environmentalsensor WHERE entity_id IN (${entityIds}) AND sensortype IN ('QA','RU') AND validity_ts>=${d1From} AND validity_ts<=${d1To} ORDER BY entity_id,validity_ts DESC`;
        CCOC.Functions.ac_executa_crate_sql(_sql,'select',2000)
            .then((data) => {
                if (!data) data=[];
                this.sensoresD1={};
                data.forEach(r=>{
                    if (!this.sensoresD1[r.entity_id]) this.sensoresD1[r.entity_id]={
                        laeq:this.sanitizaRuido(r.laeq),pm10:this.sanitizaPoluente(r.pm10),pm25:this.sanitizaPoluente(r.pm25),
                        no2:this.sanitizaPoluente(r.no2),o3:this.sanitizaPoluente(r.o3),so2:this.sanitizaPoluente(r.so2)
                    };
                });
                console.log(`📅 D-1: ${Object.keys(this.sensoresD1).length} estações`);
                this.updateAmbienteCards();
            })
            .catch(err=>{console.warn("D-1:",err);this.sensoresD1={};this.updateAmbienteCards();});
    }

    _deltaHTML(atual, anterior, unidade) {
        if (atual==null||anterior==null) return `<span class="pl-delta flat">s/ ref. D-1</span>`;
        const diff=atual-anterior;
        if (Math.abs(diff)<0.5) return `<span class="pl-delta flat">▶ igual D-1</span>`;
        const sinal=diff>0?'+':'', cls=diff>0?'up':'down';
        return `<span class="pl-delta ${cls}">${sinal}${diff.toFixed(1)}${unidade} D-1</span>`;
    }

    _renderEstacoesSelector() {
        const selQA=document.getElementById('select-qa'), selRU=document.getElementById('select-ru');
        if (!selQA||!selRU) return;
        const makeOptions=(lista,selecId)=>lista.map((r,i)=>{
            const num=String(i+1).padStart(2,'0');
            return `<option value="${r.entity_id}"${r.entity_id===selecId?' selected':''}>${num} · ${r.station.trim()}</option>`;
        }).join('');
        selQA.innerHTML=makeOptions(this.sensoresAllData.filter(r=>r.sensortype==='QA'),this.estacaoQASelec);
        selRU.innerHTML=makeOptions(this.sensoresAllData.filter(r=>r.sensortype==='RU'),this.estacaoRUSelec);
        window._scor=this;
    }

    selectEstacao(tipo, entityId) {
        if (tipo === 'QA') this.estacaoQASelec = entityId;
        if (tipo === 'RU') this.estacaoRUSelec = entityId;
        this._renderEstacoesSelector();
        // Forçar redraw do layer para aplicar o highlight
        if (this.sensoresLayer) this.sensoresLayer.changed();
        this.updateAmbienteCards();
    }

    refreshSensoresLayer() {
        if (!this.map || !this._mlReady) return;
        const feats = this.sensoresAllData.map(r => {
            const stype = r.sensortype;
            const emoji = stype==='QA'?'💨':stype==='RU'?'🔊':'🌤️';
            const selected = (stype==='QA'&&r.entity_id===this.estacaoQASelec)||(stype==='RU'&&r.entity_id===this.estacaoRUSelec);
            return {type:'Feature',geometry:{type:'Point',coordinates:[r._lon,r._lat]},
                properties:{entity_id:r.entity_id,station:r.station,sensortype:stype,
                    emoji,selected,laeq:r.laeq,pm10:r.pm10,pm25:r.pm25,no2:r.no2,o3:r.o3,temperature:r.temperature}};
        });
        this._mlSetSource('sensores', feats);
        const btnAmb = document.getElementById('btn-ambiente');
        const v = btnAmb && btnAmb.classList.contains('active') ? 'visible' : 'none';
        ['sensores-halo','sensores-body','sensores-sym'].forEach(id => {
            if (this.map.getLayer(id)) this.map.setLayoutProperty(id,'visibility',v);
        });
    }

    // ─── Posicionamento fixo do selector ────────────────────────
    // Calcula posição em relação à janela para não se mover com scroll

    _positionSelector(el) {
        // Posicionar pelo canto inferior direito do mapa
        const mapEl = document.getElementById('map') || document.querySelector('.map-area');
        const ref   = mapEl ? mapEl.getBoundingClientRect() : document.body.getBoundingClientRect();
        el.style.position = 'fixed';
        el.style.top      = 'auto';
        el.style.bottom   = Math.max(10, window.innerHeight - ref.bottom + 20) + 'px';
        el.style.right    = Math.max(10, window.innerWidth  - ref.right  + 12) + 'px';
        el.style.zIndex   = '99999';
    }

    // ─── Badges D-1 no mapa ──────────────────────────────────────

    _updateBadgesD1() {
        const badgeAr = document.getElementById('badge-ar');
        const badgeRu = document.getElementById('badge-ru');
        const btnAmb  = document.getElementById('btn-ambiente');
        const visible = btnAmb && btnAmb.classList.contains('active');

        // ── Ar ────────────────────────────────────────────────────
        if (badgeAr) {
            const qaDados = this.sensoresAllData.filter(r => r.sensortype === 'QA');
            const r  = qaDados.find(r => r.entity_id === this.estacaoQASelec) || qaDados[0];
            const d1 = r ? (this.sensoresD1 || {})[r.entity_id] || {} : {};

            const poluentes = [
                { key: 'pm10', label: 'PM10',  un: ' µg/m³' },
                { key: 'pm25', label: 'PM2.5', un: ' µg/m³' },
                { key: 'no2',  label: 'NO₂',   un: ' µg/m³' },
                { key: 'o3',   label: 'O₃',    un: ' µg/m³' },
                { key: 'so2',  label: 'SO₂',   un: ' µg/m³' }
            ];

            // Recolher todas as variações significativas
            const variacoes = [];
            poluentes.forEach(p => {
                const atual = r?.[p.key], anterior = d1[p.key];
                if (atual == null || atual === 0 || anterior == null) return;
                const diff = atual - anterior;
                if (Math.abs(diff) < 0.5) return;
                const sinal = diff < 0 ? '↓' : '↑';
                const cls   = diff < 0 ? 'melhor' : 'pior';
                variacoes.push({ label: p.label, diff, sinal, un: p.un, cls });
            });

            if (visible && r && variacoes.length > 0) {
                // Tendência global: maioria melhor ou pior?
                const nMelhor = variacoes.filter(v => v.diff < 0).length;
                const nPior   = variacoes.filter(v => v.diff > 0).length;
                const tendencia = nMelhor > nPior ? 'melhor' : nPior > nMelhor ? 'pior' : 'misto';
                const textoTend = tendencia === 'melhor' ? 'melhor que ontem' : tendencia === 'pior' ? 'pior que ontem' : 'misto face a ontem';

                let linhasVar = variacoes.map(v =>
                    `<span class="${v.cls}" style="font-size:10px">${v.label} ${v.sinal} ${Math.abs(v.diff).toFixed(1)}${v.un}</span>`
                ).join(' &nbsp;·&nbsp; ');

                badgeAr.innerHTML = `
                    <div class="badge-label">💨 Qualidade do Ar</div>
                    <div class="badge-val ${tendencia === 'misto' ? 'igual' : tendencia}">${textoTend}</div>
                    <div style="margin-top:3px;line-height:1.6">${linhasVar}</div>`;
                badgeAr.style.display = 'block';
            } else if (visible && r && variacoes.length === 0 && r.pm10 != null) {
                badgeAr.innerHTML = `<div class="badge-label">💨 Qualidade do Ar</div><div class="badge-val igual">igual a ontem</div>`;
                badgeAr.style.display = 'block';
            } else {
                badgeAr.style.display = 'none';
            }
        }

        // ── Ruído ─────────────────────────────────────────────────
        if (badgeRu) {
            const ruDados = this.sensoresAllData.filter(r => r.sensortype === 'RU');
            const r = ruDados.find(r => r.entity_id === this.estacaoRUSelec) || ruDados[0];
            const d1 = r ? (this.sensoresD1 || {})[r.entity_id] || {} : {};
            const atual = r?.laeq, anterior = d1.laeq;

            if (visible && r && atual != null && anterior != null) {
                const diff = atual - anterior;
                const absDiff = Math.abs(diff).toFixed(1);
                let cls, texto;
                if (Math.abs(diff) < 0.5) {
                    cls = 'igual'; texto = `igual a ontem`;
                } else if (diff < 0) {
                    cls = 'melhor'; texto = `melhor que ontem (LAeq ↓ ${absDiff} dBA)`;
                } else {
                    cls = 'pior'; texto = `pior que ontem (LAeq ↑ ${absDiff} dBA)`;
                }
                badgeRu.innerHTML = `<div class="badge-label">🔊 Ruído</div><div class="badge-val ${cls}">${texto}</div>`;
                badgeRu.style.display = 'block';
            } else {
                badgeRu.style.display = 'none';
            }
        }
    }

    // ─── Cards ambientais ────────────────────────────────────────

    updateAmbienteCards() {

        // ── AR — estação selecionada, apresentação limpa ─────────
        const qaDados = this.sensoresAllData.filter(r => r.sensortype === 'QA');
        const arEl    = document.getElementById('ar-card');
        if (arEl) {
            if (!qaDados.length) {
                arEl.innerHTML = `<b>💨 Qualidade do Ar</b><div class="big-number">—</div><div class="big-number-sub">sem dados</div>`;
            } else {
                const r = qaDados.find(r => r.entity_id === this.estacaoQASelec) || qaDados[0];
                const c = this.classificaAr(r.pm10, r.pm25, r.no2, r.o3);
                const poluentes = [
                    { key: 'pm10', label: 'PM10',  un: ' µg/m³' },
                    { key: 'pm25', label: 'PM2.5', un: ' µg/m³' },
                    { key: 'no2',  label: 'NO₂',   un: ' µg/m³' },
                    { key: 'o3',   label: 'O₃',    un: ' µg/m³' },
                    { key: 'so2',  label: 'SO₂',   un: ' µg/m³' }
                ];
                let linhas = '';
                poluentes.forEach(p => {
                    const val = r[p.key];
                    if (val == null || val === 0) return;
                    linhas += `<div class="param-linha"><span class="pl-label">${p.label}</span><span class="pl-val">${val.toFixed(0)}${p.un}</span></div>`;
                });
                arEl.innerHTML = `<b>💨 Qualidade do Ar</b>
                    <div class="card-estacao-nome" title="${r.station}">${r.station}</div>
                    <div class="card-classif-label" style="color:${c.cor}">${c.label}</div>
                    ${linhas}`;
            }
        }

        // ── RUÍDO — estação selecionada, apresentação limpa ──────
        const ruDados = this.sensoresAllData.filter(r => r.sensortype === 'RU');
        const ruEl    = document.getElementById('ruido-card');
        if (ruEl) {
            if (!ruDados.length) {
                ruEl.innerHTML = `<b>🔊 Ruído</b><div class="big-number">—</div><div class="big-number-sub">sem dados</div>`;
            } else {
                const r = ruDados.find(r => r.entity_id === this.estacaoRUSelec) || ruDados[0];
                const c = this.classificaRuido(r.laeq);
                ruEl.innerHTML = `<b>🔊 Ruído</b>
                    <div class="card-estacao-nome" title="${r.station}">${r.station}</div>
                    <div class="big-number" style="color:${c.cor}">${c.emoji} ${r.laeq != null ? r.laeq.toFixed(1) : '—'}<span class="unit-small" style="color:${c.cor}"> dBA</span></div>
                    <div class="card-classif-label" style="color:${c.cor}">${c.label}</div>`;
            }
        }

        // ── TEMPERATURA — média, sem alterações ──────────────────
        const meDados = this.sensoresAllData.filter(r => r.sensortype === 'ME' && r.temperature != null);
        const tempEl  = document.getElementById('temp-card');
        if (tempEl) {
            if (!meDados.length) {
                tempEl.innerHTML = `<b>🌡️ Temperatura</b><div class="big-number">—</div><div class="big-number-sub">sem dados</div>`;
            } else {
                const vals = meDados.map(r => r.temperature);
                const media = vals.reduce((a,c) => a+c, 0) / vals.length;
                const min = Math.min(...vals), max = Math.max(...vals);
                const humVals = meDados.map(r => r.humidity).filter(v => v != null);
                const humMedia = humVals.length ? humVals.reduce((a,c) => a+c, 0) / humVals.length : null;
                const c = this.classificaTemp(media);
                tempEl.innerHTML = `<b>🌡️ Temperatura</b>
                    <div class="big-number" style="color:${c.cor}">${c.emoji} ${media.toFixed(1)}<span class="unit-small" style="color:${c.cor}">°C</span></div>
                    <div class="big-number-sub" style="color:${c.cor};font-weight:bold;text-transform:uppercase;letter-spacing:0.5px">${c.label}</div>
                    <div style="display:flex;gap:8px;margin-top:4px;font-size:10px">
                        <span style="color:#7fb3ed">⬇ ${min.toFixed(1)}°</span>
                        <span style="color:#ff8a8a">⬆ ${max.toFixed(1)}°</span>
                        ${humMedia != null ? `<span style="color:#a9d6ff">💧 ${humMedia.toFixed(0)}%</span>` : ''}
                    </div>`;
            }
        }

        // Atualizar badges no mapa depois de ter os dados
        this._updateBadgesD1();
    }

