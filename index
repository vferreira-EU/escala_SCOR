                    const dirN=(dir==='DESC'||dir==='DESCENDING')?'DESC':'ASC';
                    feats.push({type:'Feature',geometry:{type:'Point',coordinates:[lon,lat]},
                        properties:{route_id:item.route_id,route_number:String(item.route_number||'?'),
                            direction:dirN,plate:item.vehicle_license_plate||'',inside}});
                    if (inside){dentroPoligono++;linhasDentro.add(String(item.route_number));}
                });
                this._mlSetSource('carris', feats);
                this.updateCarrisCard(dentroPoligono,linhasDentro);
            })
            .catch(err=>{console.warn("Carris falhou:",err);this.updateCarrisCard(0,new Set());});
